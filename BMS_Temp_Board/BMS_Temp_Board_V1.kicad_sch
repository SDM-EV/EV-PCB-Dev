	(text "Power Net Names:\n\nAny voltage Like 3.3v or 5v comes\nfrom a regulator on board.\n\nVBUS comes from a USB connection\n\nVCC comes from the car/anywhere \noutside the board.\n\nGND/VDD = Ground"
		(exclude_from_sim no)
		(at 99.822 29.718 0)
		(effects
			(font
				(size 1.7 1.7)
