	(text "TPS25925x Calculations\nTPS259250 = Latch on fault,\n TPS259251 = auto retry on fault\nResitor @ ILIM pin calc = (ILIM (max current) - 0.7) / (3 * (10 ^ -5))\n(LMC - 0.7) / (3 * (10 ^ -5)) = 60k Ohm\nUndervoltage Lockout Set = V_(UV) = ((R_1 + R_2) /R_2) * V_ENR (1.4 Given)\nLeft open so default value of V_(UV) is 4.3V\n"
		(exclude_from_sim no)
		(at 241.046 94.742 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "947c899a-c9fc-4746-9bf9-9b51d20eb605")
	)
